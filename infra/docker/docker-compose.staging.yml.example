# Reference-only staging topology for Block XY.
# Copy to a private, untracked location and fill secrets through your platform.
# Never commit real credentials, customer data, or production connection strings.

name: closeros-staging-reference

services:
  api:
    image: closeros-api:staging
    build:
      context: ../..
      dockerfile: infra/docker/Dockerfile.api
    environment:
      APP_ENV: production
      DATABASE_URL: ${DATABASE_URL:?set DATABASE_URL to Supabase pooler URI}
      REDIS_URL: ${REDIS_URL:?set REDIS_URL to managed Redis}
      AUTH_ALLOWED_ORIGINS: ${STAGING_WEB_URL:?set STAGING_WEB_URL}
      AUTH_CSRF_SECRET: ${AUTH_CSRF_SECRET:?required}
      AUTH_RATE_LIMIT_SECRET: ${AUTH_RATE_LIMIT_SECRET:?required}
      INGESTION_SERVICE_ID: ${INGESTION_SERVICE_ID:?required}
      APP_ENCRYPTION_KEY: ${APP_ENCRYPTION_KEY:?required}
      AI_EXTERNAL_CALLS_ENABLED: "false"
    ports:
      - "8000:8000"
    healthcheck:
      test: ["CMD-SHELL", "python -c \"import urllib.request; urllib.request.urlopen('http://127.0.0.1:8000/health')\""]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 40s
    depends_on:
      redis:
        condition: service_healthy
    networks:
      - staging_reference

  worker:
    image: closeros-worker:staging
    build:
      context: ../..
      dockerfile: infra/docker/Dockerfile.worker
    environment:
      APP_ENV: production
      DATABASE_URL: ${DATABASE_URL:?set DATABASE_URL}
      REDIS_URL: ${REDIS_URL:?set REDIS_URL}
      WORKER_ID: ${WORKER_ID:-staging-worker-1}
      OUTBOX_STREAM: closeros.outbox.jobs
      OUTBOX_CONSUMER_GROUP: closeros.outbox.processors
      APP_ENCRYPTION_KEY: ${APP_ENCRYPTION_KEY:?required}
      AI_EXTERNAL_CALLS_ENABLED: "false"
    depends_on:
      redis:
        condition: service_healthy
    networks:
      - staging_reference

  web:
    image: closeros-web:staging
    build:
      context: ../..
      dockerfile: infra/docker/Dockerfile.web
      args:
        NEXT_PUBLIC_API_BASE_URL: ${STAGING_API_URL:?set STAGING_API_URL}
    environment:
      PORT: "3000"
    ports:
      - "3000:3000"
    depends_on:
      api:
        condition: service_healthy
    networks:
      - staging_reference

  redis:
    image: redis:8.8.0-trixie
    command: ["redis-server", "--appendonly", "yes", "--requirepass", "${REDIS_PASSWORD:?required}"]
    environment:
      REDIS_PASSWORD: ${REDIS_PASSWORD:?required}
    healthcheck:
      test: ["CMD-SHELL", "redis-cli -a \"$$REDIS_PASSWORD\" ping | grep PONG"]
      interval: 5s
      timeout: 5s
      retries: 10
    networks:
      - staging_reference

networks:
  staging_reference:
    driver: bridge

# PostgreSQL is intentionally omitted. Staging uses Supabase-managed PostgreSQL.
# See infra/supabase/README.md and docs/STAGING_SUPABASE.md.
