{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://closeros.ai/schemas/v1/message.json",
  "title": "Message",
  "description": "Immutable provider-neutral message metadata. No message body fields. Version 1.0.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "tenant_id",
    "conversation_thread_id",
    "external_message_id",
    "sender_type",
    "direction",
    "sent_at",
    "received_at",
    "adapter_metadata"
  ],
  "properties": {
    "schema_version": { "$ref": "#/$defs/schemaVersion" },
    "id": { "$ref": "#/$defs/uuid" },
    "tenant_id": { "$ref": "#/$defs/uuid" },
    "conversation_thread_id": { "$ref": "#/$defs/uuid" },
    "external_message_id": { "$ref": "#/$defs/externalId" },
    "sender_type": { "$ref": "#/$defs/participantSenderType" },
    "direction": { "$ref": "#/$defs/messageDirection" },
    "sent_at": { "$ref": "#/$defs/timestamp" },
    "received_at": { "$ref": "#/$defs/timestamp" },
    "content_id": {
      "oneOf": [{ "$ref": "#/$defs/uuid" }, { "type": "null" }],
      "description": "Opaque reference to encrypted content storage. Not inline text."
    },
    "reply_to_message_id": {
      "oneOf": [{ "$ref": "#/$defs/uuid" }, { "type": "null" }]
    },
    "adapter_metadata": { "$ref": "#/$defs/adapterMetadata" }
  },
  "$defs": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "uuid": {
      "type": "string",
      "format": "uuid"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": ".*(Z|[+-]\\d{2}:\\d{2})$"
    },
    "externalId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "adapterMetadata": {
      "type": "object",
      "maxProperties": 32,
      "additionalProperties": {
        "oneOf": [
          { "type": "string", "minLength": 1, "maxLength": 512 },
          { "type": "integer" },
          { "type": "boolean" },
          { "type": "null" }
        ]
      },
      "propertyNames": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64,
        "not": {
          "pattern": "(?i).*(body|text|message|content|token|secret|password|authorization|cookie|email|phone|payload).*"
        }
      }
    },
    "participantSenderType": {
      "type": "string",
      "enum": ["customer", "bot", "manager", "system", "unknown"]
    },
    "messageDirection": {
      "type": "string",
      "enum": ["inbound", "outbound"]
    }
  }
}
