{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://closeros.ai/schemas/v1/lead.json",
  "title": "Lead",
  "description": "Provider-neutral lead identity record. Version 1.0.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "tenant_id",
    "external_identity_id",
    "status",
    "adapter_metadata",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": { "$ref": "#/$defs/schemaVersion" },
    "id": { "$ref": "#/$defs/uuid" },
    "tenant_id": { "$ref": "#/$defs/uuid" },
    "external_identity_id": { "$ref": "#/$defs/externalId" },
    "status": { "$ref": "#/$defs/leadStatus" },
    "adapter_metadata": { "$ref": "#/$defs/adapterMetadata" },
    "created_at": { "$ref": "#/$defs/timestamp" },
    "updated_at": { "$ref": "#/$defs/timestamp" }
  },
  "$defs": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "uuid": {
      "type": "string",
      "format": "uuid"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": ".*(Z|[+-]\\d{2}:\\d{2})$"
    },
    "externalId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "adapterMetadata": {
      "type": "object",
      "maxProperties": 32,
      "additionalProperties": {
        "oneOf": [
          { "type": "string", "minLength": 1, "maxLength": 512 },
          { "type": "integer" },
          { "type": "boolean" },
          { "type": "null" }
        ]
      },
      "propertyNames": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64,
        "not": {
          "pattern": "(?i).*(body|text|message|content|token|secret|password|authorization|cookie|email|phone|payload).*"
        }
      }
    },
    "leadStatus": {
      "type": "string",
      "enum": ["active", "merged", "archived"]
    }
  }
}
