{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://closeros.ai/schemas/v1/whatsapp-connection.json",
  "title": "WhatsAppConnectionV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "channel_connection_id",
    "provider",
    "app_id",
    "waba_id",
    "phone_number_id",
    "graph_api_version",
    "status",
    "webhook_subscription_status",
    "capabilities",
    "webhook_public_key",
    "webhook_callback_path",
    "created_at",
    "updated_at",
    "version"
  ],
  "properties": {
    "id": { "$ref": "./enums.json#/$defs/uuid" },
    "channel_connection_id": { "$ref": "./enums.json#/$defs/uuid" },
    "provider": { "const": "whatsapp_cloud" },
    "app_id": { "type": "string", "minLength": 1, "maxLength": 64 },
    "waba_id": { "type": "string", "minLength": 1, "maxLength": 64 },
    "phone_number_id": { "type": "string", "minLength": 1, "maxLength": 64 },
    "display_phone_number": { "type": ["string", "null"], "maxLength": 32 },
    "graph_api_version": { "type": "string", "minLength": 1, "maxLength": 16 },
    "access_token_ref": { "type": ["string", "null"], "maxLength": 64 },
    "app_secret_ref": { "type": ["string", "null"], "maxLength": 64 },
    "verify_token_ref": { "type": ["string", "null"], "maxLength": 64 },
    "status": {
      "enum": [
        "draft",
        "verification_pending",
        "active",
        "degraded",
        "disabled"
      ]
    },
    "webhook_subscription_status": {
      "enum": ["not_configured", "pending", "subscribed", "failed"]
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "inbound_text",
          "interactive_reply",
          "reaction",
          "message_status",
          "media_reference",
          "outbound_free_form_text",
          "outbound_approved_template"
        ]
      }
    },
    "webhook_public_key": {
      "type": "string",
      "minLength": 32,
      "maxLength": 64
    },
    "webhook_callback_path": { "type": "string", "minLength": 1 },
    "created_at": { "$ref": "./enums.json#/$defs/timestamp" },
    "updated_at": { "$ref": "./enums.json#/$defs/timestamp" },
    "last_verified_at": {
      "oneOf": [{ "$ref": "./enums.json#/$defs/timestamp" }, { "type": "null" }]
    },
    "version": { "type": "integer", "minimum": 1 }
  }
}
