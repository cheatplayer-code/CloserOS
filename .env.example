# Local development only. Never place production secrets here.

APP_ENV=development
APP_NAME=closeros
LOG_LEVEL=INFO

# CLS-002 local infrastructure only.
# These committed fallback values are public, intentionally non-production,
# and forbidden in staging or production. Copy this file to an untracked .env
# only when overriding a value for local development.
POSTGRES_DB=closeros_local
POSTGRES_USER=closeros_local
POSTGRES_PASSWORD=closeros_local_only_change_me
POSTGRES_HOST_PORT=5432

REDIS_PASSWORD=closeros_local_redis_only_change_me
REDIS_HOST_PORT=6379

# Reserved for later application integration; CLS-002 does not read these URLs.
# If a local password is changed to include reserved URL characters, percent-encode
# that password in the corresponding URL.
# The three URI lines below are committed public local-development examples, not
# production credentials. trufflehog:ignore applies only to these exact example
# URIs. Real secrets must never use trufflehog:ignore.
DATABASE_URL=postgresql://closeros_local:closeros_local_only_change_me@127.0.0.1:5432/closeros_local # trufflehog:ignore

# LOCAL DEVELOPMENT ONLY. Used by authentication persistence integration tests to
# create isolated temporary databases. The admin connection must target the
# PostgreSQL maintenance database (postgres), not an application database.
TEST_DATABASE_URL=postgresql://closeros_local:closeros_local_only_change_me@127.0.0.1:5432/postgres # trufflehog:ignore
REDIS_URL=redis://:closeros_local_redis_only_change_me@127.0.0.1:6379/0 # trufflehog:ignore

# LOCAL DEVELOPMENT ONLY — worker outbox processing.
WORKER_ID=
WORKER_POLLING_INTERVAL_SECONDS=1
WORKER_PUBLISH_BATCH_SIZE=25
WORKER_PROCESSOR_BLOCK_MS=5000
OUTBOX_STREAM=closeros.outbox.jobs
OUTBOX_CONSUMER_GROUP=closeros.outbox.processors

# LOCAL DEVELOPMENT ONLY — ingestion limits and synthetic provider adapter.
# Leave SYNTHETIC_WEBHOOK_SECRET blank to use deterministic dev-only bytes(range(32)).
# Never reuse synthetic secrets outside local development.
WEBHOOK_MAX_BODY_BYTES=1048576
CSV_MAX_BODY_BYTES=10485760
INGESTION_SERVICE_ID=
SYNTHETIC_WEBHOOK_SECRET=
# Never reuse development secrets in staging or production.
AUTH_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
AUTH_CSRF_SECRET=closeros_local_csrf_only_not_production_32b
AUTH_RATE_LIMIT_SECRET=closeros_local_rate_only_not_production_32b
AUTH_SESSION_TOUCH_MINUTES=5
AUTH_TRUST_FORWARDED_CLIENT_IP=false

# LOCAL DEVELOPMENT ONLY — frontend authentication API target.
# Use the same hostname family as the browser origin (prefer localhost, not 127.0.0.1).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# External providers are disabled by default. When enabled, the API fails closed
# unless the key, HTTPS base URL, and model are all configured.
AI_EXTERNAL_CALLS_ENABLED=false
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/
DEEPSEEK_MODEL=deepseek-v4-flash
# Optional OpenAI-compatible endpoint for NOPQ gateway adapters.
# Keep blank in local tests unless explicitly running sanctioned sandbox checks.
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
# Dev-only deterministic knowledge lexical search key (64 hex chars, optional).
# Leave blank to use deterministic development fallback in local mode.
CLOSEROS_DEV_KNOWLEDGE_SEARCH_KEY_HEX=

# LOCAL DEVELOPMENT ONLY — WhatsApp Cloud (Block VW).
# Reference keys on whatsapp_cloud_connections point to these env var names.
# Construct secrets at runtime; never commit real Meta credentials.
WHATSAPP_GRAPH_API_VERSION=v21.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=

# S2 managed staging only. Generate independent 32-byte values and store them
# as sealed Railway variables. Never commit real values or reuse them in production.
STAGING_ENCRYPTION_KEY_HEX=
STAGING_ENCRYPTION_KEY_VERSION=staging-kek-v1
STAGING_KNOWLEDGE_SEARCH_KEY_HEX=

# Block XY/S2 — staging URLs (blank until provisioned; never commit real hosts with secrets)
STAGING_API_URL=
STAGING_WEB_URL=

# Block Z0/S2 — synthetic and DeepSeek staging smoke.
# Password and account identifiers come from environment variables only; never CLI args.
# SMOKE_USER_EMAIL=
# SMOKE_USER_PASSWORD=
# SMOKE_EXPECTED_TENANT_ID=
# SMOKE_CONVERSATION_THREAD_ID=
# SMOKE_EXPECTED_AI_PROVIDER=openai
# SMOKE_EXPECTED_AI_MODEL=deepseek-v4-flash

# Optional production feature gates (default false)
WHATSAPP_ENABLED=false
CRM_ENABLED=false
NOTIFICATIONS_ENABLED=false

# Block XY — SMTP (transactional email; disabled until provider approved)
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM_ADDRESS=
SMTP_USERNAME_REF=
SMTP_PASSWORD_REF=
SMTP_TRANSPORT=starttls

# Block XY — production remote KMS (required when APP_ENV=production)
KMS_BASE_URL=
KMS_API_TOKEN_REF=
KMS_ACTIVE_KEY_VERSION=
KMS_KEY_VERSIONS=
KNOWLEDGE_SEARCH_KEY_REF=
KNOWLEDGE_SEARCH_KEY_VERSION=

# Block XY — Bitrix24 CRM production references (disabled by default)
BITRIX24_PORTAL_DOMAIN=
BITRIX24_ACCESS_TOKEN_REF=

# Block XY — Redis-backed authentication rate limiting (staging/production)
REDIS_RATE_LIMIT_ENABLED=false
REDIS_RATE_LIMIT_PREFIX=closeros:ratelimit
REDIS_RATE_LIMIT_HMAC_SECRET=

# Block XY — media scanning placeholders (pipeline not enabled)
MEDIA_SCANNER_ENABLED=false
MEDIA_OBJECT_STORE_BUCKET=
MEDIA_OBJECT_STORE_REGION=
